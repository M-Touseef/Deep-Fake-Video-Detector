# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/proof-of-reality

# ML Service Configuration
# Local development: Flask runs on port 5000
ML_SERVICE_URL=http://localhost:5000/predict
# Production (Azure Container Apps): uncomment and set your deployed URL
# ML_SERVICE_URL=https://<app-name>.<region>.azurecontainerapps.io/predict
ML_SERVICE_TIMEOUT=300000

# File Upload Configuration (50 MB — same cap as ML Flask service)
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
HEATMAP_DIR=./heatmaps

# JWT Configuration (Optional - for future auth)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d
