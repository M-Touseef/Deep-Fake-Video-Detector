# Server
NODE_ENV=production
PORT=3000

# Database
# Use a production MongoDB connection string, for example MongoDB Atlas.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# ML service
# Must include /predict because the backend posts videos directly to this endpoint.
ML_SERVICE_URL=https://<ml-container-app-url>/predict
ML_SERVICE_TIMEOUT=300000

# Upload/runtime storage
# These are ephemeral on most app hosts unless you attach persistent disks.
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
HEATMAP_DIR=./heatmaps
VIDEO_RETENTION_HOURS=12
CLEANUP_INTERVAL_MINUTES=60

# Auth/admin
JWT_SECRET=<generate-a-long-random-secret>
JWT_EXPIRES_IN=7d
AUTH_TOKEN_TTL_MS=604800000
ADMIN_EMAIL=admin@deepfake.com
ADMIN_PASSWORD=<set-a-strong-admin-password>
ADMIN_NAME=Admin User
